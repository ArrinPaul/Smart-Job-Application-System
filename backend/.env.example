# ============================================
# RAILWAY MYSQL - CLOUD DATABASE CONFIG
# ============================================
# Copy this file to .env and fill in your actual Railway credentials
MYSQLHOST=switchyard.proxy.rlwy.net
MYSQLPORT=16937
MYSQLDATABASE=railway
MYSQLUSER=root
MYSQLPASSWORD=YOUR_RAILWAY_PASSWORD_HERE

# ============================================
# SERVER CONFIGURATION
# ============================================
SERVER_PORT=8080
HIKARI_MAX_POOL=20

# ============================================
# SECURITY CONFIGURATION
# ============================================
JWT_SECRET=YOUR_STRONG_SECRET_KEY_HERE
JWT_EXPIRATION=86400000
AUTH_COOKIE_NAME=AUTH_TOKEN
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=Strict
MAX_REQUEST_BYTES=1048576
AUTH_RATE_LIMIT_CAPACITY=5
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
CAPTCHA_ENABLED=false
CAPTCHA_SECRET=
CAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify
MFA_ISSUER=SmartJobPortal
MFA_ENFORCE_SENSITIVE_ACTIONS=true
FRONTEND_BASE_URL=http://localhost:4200

# ============================================
# FRONTEND CORS
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# ============================================
# LOGGING
# ============================================
LOG_PATH=logs

# ============================================
# ADMIN BOOTSTRAP
# ============================================
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_EMAIL=YOUR_EMAIL_HERE
ADMIN_BOOTSTRAP_PASSWORD=YOUR_STRONG_ADMIN_PASSWORD

# ============================================
# SAMPLE DATA (DEV ONLY)
# ============================================
DATA_LOADER_ENABLED=false
DATA_LOADER_SAMPLE_PASSWORD=ChangeMe123!
