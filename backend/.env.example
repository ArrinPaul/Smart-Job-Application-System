# ============================================
# SERVER CONFIGURATION
# ============================================
SPRING_PROFILES_ACTIVE=supabase
SERVER_PORT=8080
HIKARI_MAX_POOL=20

# ============================================
# SECURITY CONFIGURATION
# ============================================
JWT_SECRET=YOUR_STRONG_SECRET_KEY_HERE
JWT_EXPIRATION=86400000
AUTH_COOKIE_NAME=AUTH_TOKEN
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=Strict
MAX_REQUEST_BYTES=1048576
AUTH_RATE_LIMIT_CAPACITY=5
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
CAPTCHA_ENABLED=false
CAPTCHA_SECRET=
CAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify
MFA_ISSUER=SmartJobPortal
MFA_ENFORCE_SENSITIVE_ACTIONS=true
FRONTEND_BASE_URL=http://localhost:4200
SECURITY_EMAIL_ENABLED=false
SECURITY_EMAIL_FROM=no-reply@jobportal.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=true
SMTP_STARTTLS=true

# ============================================
# FRONTEND CORS
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# ============================================
# LOGGING
# ============================================
LOG_PATH=logs

# ============================================
# ADMIN BOOTSTRAP
# ============================================
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_EMAIL=YOUR_EMAIL_HERE
ADMIN_BOOTSTRAP_PASSWORD=

# ============================================
# SAMPLE DATA (DEV ONLY)
# ============================================
DATA_LOADER_ENABLED=false
DATA_LOADER_SAMPLE_PASSWORD=ChangeMe123!

# ============================================
# SUPABASE POSTGRES (OPTIONAL PROFILE)
# ============================================
# Enable with: SPRING_PROFILES_ACTIVE=supabase
# Use the Supabase database connection details from Project Settings -> Database.
# Note: SUPABASE_ANON_KEY is for frontend client use and does not replace DB credentials.
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_ANON_KEY=

# ============================================
# SECURITY AUDIT
# ============================================
NVD_API_KEY=YOUR_NVD_API_KEY
