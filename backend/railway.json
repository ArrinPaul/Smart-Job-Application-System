{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "context": ".",
    "dockerfile": "Dockerfile"
  },
  "deploy": {
    "restartPolicyType": "always",
    "restartPolicyMaxRetries": 5,
    "startCommand": "java -Dserver.port=$PORT -jar target/jobportalsystem-0.0.1-SNAPSHOT.jar",
    "numReplicas": 1,
    "healthchecks": {
      "readiness": {
        "initialDelaySeconds": 60,
        "periodSeconds": 10,
        "timeoutSeconds": 5,
        "failureThreshold": 3
      },
      "liveness": {
        "initialDelaySeconds": 120,
        "periodSeconds": 30,
        "timeoutSeconds": 5,
        "failureThreshold": 3
      }
    }
  }
}
